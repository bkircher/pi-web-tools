{
	"name": "@bkircher/pi-web-tools",
	"version": "0.1.0",
	"keywords": [
		"pi-package"
	],
	"type": "module",
	"scripts": {
		"lint": "biome lint .",
		"format": "biome format --write .",
		"test": "tsx --test tests/*.test.ts",
		"typecheck": "tsc"
	},
	"files": [
		"extensions"
	],
	"pi": {
		"extensions": [
			"./extensions"
		]
	},
	"engines": {
		"node": ">=26"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "^0.80.0",
		"@earendil-works/pi-coding-agent": "^0.80.0",
		"@earendil-works/pi-tui": "^0.80.0",
		"typebox": "^1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"tsx": "^4.23.0",
		"typescript": "^7.0.2"
	},
	"description": "Provides web_search and web_fetch tools to pi",
	"author": "bkircher@0xadd.de",
	"license": "MIT",
	"dependencies": {
		"parse5": "^8.0.1"
	}
}
